APP_NAME=Student Weather Assistant
API_PREFIX=/api/v1
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
HTTP_TIMEOUT_SECONDS=10
CORS_ORIGINS=["http://localhost:15173","http://localhost:5173","http://localhost:3000"]
VITE_API_BASE_URL=http://localhost:18080
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Weather Provider Configuration
WEATHER_PROVIDER=openweather
WEATHER_FALLBACK_PROVIDER=open_meteo
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org
OPEN_METEO_BASE_URL=https://api.open-meteo.com
DEBUG_WEATHER_COMPARE=false

# Database Configuration
POSTGRES_DB=student_weather
POSTGRES_USER=student_weather_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://student_weather_user:change_me@localhost:15432/student_weather

# JWT Config
JWT_SECRET_KEY=change_me_to_a_secure_random_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Login Config (Optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:18080/api/v1/auth/google/callback
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Notification Provider Configuration (Optional)
# A. SMTP Configuration (Gmail, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_username_here
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_EMAIL=your_gmail_address_here
SMTP_USE_TLS=true

# B. Resend Configuration (Alternative)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=no-reply@yourdomain.com

# C. SendGrid Configuration (Alternative)
SENDGRID_API_KEY=your_sendgrid_api_key_here

